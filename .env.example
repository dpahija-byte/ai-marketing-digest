# LLM provider. Use "auto", "openai", "anthropic" or "mock".
LLM_PROVIDER=auto

# Set one of these for real generation.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional model overrides.
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-haiku-latest
USE_LLM_RANKING=false
MAX_POST_CHARS=2600

# Optional AI image generation for the public article.
IMAGE_ENABLED=true
IMAGE_STATIC_PATH=assets/brand/daniele-pahija-hero.jpeg
IMAGE_MODEL=gpt-image-1
IMAGE_SIZE=1536x1024
IMAGE_QUALITY=medium

# Runtime overrides.
WINDOW_HOURS=48
MAX_ARTICLES=5
MAX_NEWSLETTER_ARTICLES=40
VOICE_FILE=voice.yaml
LOG_LEVEL=INFO
USER_AGENT=ai-marketing-digest/0.1 (+https://example.com/bot)

# Optional email delivery.
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
# Optional safety lock. If set, SMTP_TO must match exactly.
EMAIL_ALLOWED_TO=

# Optional Telegram delivery.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
